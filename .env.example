# Database — PostgreSQL connection string
# Local dev: postgresql://postgres:password@localhost:5432/nobsppt
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nobsppt

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here-at-least-32-chars

# Anthropic API key — for restraint engine deck generation (Story 2.2)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for HTTPS redirect check)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — Story 4.2 subscription checkout
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — get from: https://dashboard.stripe.com/webhooks
# Local dev: use Stripe CLI → `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro plan — create at: https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_...
