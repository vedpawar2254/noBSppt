# Database — PostgreSQL connection string
# Local dev: postgresql://postgres:password@localhost:5432/nobsppt
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nobsppt

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here-at-least-32-chars

# OpenRouter — AI generation via multi-model API (Story 6.1)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Model to use — any OpenRouter model ID. Cheap options that handle structured JSON well:
#   google/gemini-2.0-flash-001          ~$0.10/$0.40 per MTok  (default — best value)
#   google/gemini-flash-1.5              ~$0.075/$0.30 per MTok
#   anthropic/claude-haiku-4-5-20251001  ~$0.80/$4.00 per MTok  (higher quality)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# DEPRECATED — replaced by OPENROUTER_API_KEY (Story 6.1)
# Keep for reference; no longer read by the application
# ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for OpenRouter HTTP-Referer header and share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — Story 4.2 subscription checkout (kept for Story 6.3 migration)
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Razorpay — INR subscription checkout (Story 6.2)
# Get keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Plan ID — create at: https://dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_ID=plan_...
# Webhook secret — set at: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
